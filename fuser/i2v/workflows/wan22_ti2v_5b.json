{
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "example.png", "upload": "image" },
    "_meta": { "title": "Imagen de entrada" }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "wan",
      "device": "cpu"
    },
    "_meta": { "title": "Cargar codificador de texto (UMT5)" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "a cinematic shot", "clip": ["2", 0] },
    "_meta": { "title": "Prompt positivo" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["2", 0] },
    "_meta": { "title": "Prompt negativo" }
  },
  "5": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "wan2.2_vae.safetensors" },
    "_meta": { "title": "Cargar VAE (2.2, para el 5B)" }
  },
  "6": {
    "class_type": "UnetLoaderGGUF",
    "inputs": { "unet_name": "Wan2.2-TI2V-5B-Q4_K_M.gguf" },
    "_meta": { "title": "Modelo TI2V 5B (GGUF, cabe en 8 GB)" }
  },
  "8": {
    "class_type": "ModelSamplingSD3",
    "inputs": { "model": ["6", 0], "shift": 8.0 },
    "_meta": { "title": "ModelSamplingSD3" }
  },
  "10": {
    "class_type": "WanImageToVideo",
    "inputs": {
      "positive": ["3", 0],
      "negative": ["4", 0],
      "vae": ["5", 0],
      "width": 640,
      "height": 480,
      "length": 49,
      "batch_size": 1,
      "start_image": ["1", 0]
    },
    "_meta": { "title": "Wan Image To Video" }
  },
  "11": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["8", 0],
      "positive": ["10", 0],
      "negative": ["10", 1],
      "latent_image": ["10", 2],
      "seed": 0,
      "steps": 20,
      "cfg": 5.0,
      "sampler_name": "uni_pc",
      "scheduler": "simple",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler (5B)" }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["11", 0], "vae": ["5", 0] },
    "_meta": { "title": "VAE Decode" }
  },
  "14": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["13", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "fuser_i2v",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true
    },
    "_meta": { "title": "Combinar vídeo (MP4)" }
  }
}
