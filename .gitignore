env/
ENV/

# Modelos descargados (pesados, se bajan en el primer uso).
# OJO: ancla con '/' para ignorar SOLO la carpeta raíz 'models/' y NO el
# paquete de código 'fuser/models/'.
/models/*
!/models/.gitkeep

